    {
      "cell_type": "code",
      "source": [
        "import torch\n",
        "\n",
        "print(\"Torch:\", torch.__version__)\n",
        "print(\"CUDA available:\", torch.cuda.is_available())\n",
        "print(\"CUDA device count:\", torch.cuda.device_count())"
      ],
      "metadata": {
        "id": "o6j7kh0lJqx1",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "8ed9f819-bbd8-4062-8725-f7d29e4333a9"
      },
      "execution_count": 13,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Torch: 2.11.0+cpu\n",
            "CUDA available: False\n",
